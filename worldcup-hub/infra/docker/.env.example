# Author: Bishakh
# Copy to ".env" (next to docker-compose.yml) to switch the simulator's data source.

# ── Option A: REAL data, NO key needed (recommended) ─────────────────────────
DATA_SOURCE=thesportsdb
# League id (4328 = English Premier League). FIFA World Cup populates during the tournament.
THESPORTSDB_LEAGUE=4328

# ── Option B: football-data.org LIVE matches (needs a free token) ────────────
# Get one at https://www.football-data.org/client/register, then:
# DATA_SOURCE=real
# FOOTBALL_API_KEY=your_token_here
# FOOTBALL_COMPETITION=WC        # WC, CL, PL, ...
# POLL_INTERVAL=20               # seconds between polls (>= 10)
