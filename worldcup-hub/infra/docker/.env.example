# Author: Bishakh
# Copy to ".env" (next to docker-compose.yml) to switch the simulator to REAL data.
# Get a free token at https://www.football-data.org/client/register

DATA_SOURCE=real
FOOTBALL_API_KEY=your_token_here
# Competition code: WC (World Cup), CL (Champions League), PL (Premier League), etc.
FOOTBALL_COMPETITION=WC
# Seconds between polls — keep >= 10 to respect the free tier (10 req/min).
POLL_INTERVAL=20
