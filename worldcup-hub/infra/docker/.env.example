# Author: Bishakh
# Copy to ".env" (next to docker-compose.yml) to switch the simulator's data source.

# ── Recommended for the FIFA World Cup 2026: football-data.org ───────────────
# Free tier includes the World Cup (fixtures, results, group standings), 10 req/min.
# Get a free token at https://www.football-data.org/client/register
DATA_SOURCE=real
FOOTBALL_API_KEY=your_token_here
FOOTBALL_COMPETITION=WC          # WC = World Cup (or CL, PL, EC, ...)
POLL_INTERVAL=20                 # seconds between polls (>= 10)

# ── Alternative: TheSportsDB (real data, NO key — but weak for the WC) ────────
# DATA_SOURCE=thesportsdb
# THESPORTSDB_LEAGUE=4328         # 4328 = English Premier League
